# Base infrastructure image. Service image digests are tracked in docker-compose.yml.
MYSQL_IMAGE=mysql:8.4

# MySQL root and per-service credentials (replace before use)
MYSQL_ROOT_PASSWORD=change-me-root
SPRING_DB_NAME=chokchok
SPRING_DB_USER=chokchok
SPRING_DB_PASSWORD=change-me-spring
FASTAPI_DB_NAME=chok_ai
FASTAPI_DB_USER=chok_ai
FASTAPI_DB_PASSWORD=change-me-fastapi

# Browser-visible addresses and CORS origin
SPRING_PUBLIC_URL=http://localhost:8080
FRONTEND_PUBLIC_ORIGIN=http://localhost:4173

# Published host ports
MYSQL_PUBLISHED_PORT=3307
SPRING_PUBLISHED_PORT=8080
FASTAPI_PUBLISHED_PORT=8000
FRONTEND_PUBLISHED_PORT=4173

# FastAPI/OpenAI settings. Set a real key before deployment.
OPENAI_API_KEY=
OPENAI_MODEL_REPORT=gpt-5.5-2026-04-23
OPENAI_MODEL_ANALYSIS=gpt-5.4-mini-2026-03-17
OPENAI_MODEL_LIGHT=gpt-5.4-nano-2026-03-17
OPENAI_MAX_CONCURRENCY=4
OPENAI_MAX_RETRIES=3
OPENAI_MAX_INPUT_CHARS=120000
RCA_WORKER_CONCURRENCY=2

# SDK collector. The host path must contain log/, metric/, and trace/.
SDK_SOURCE_PATH=/srv/chok-v2/source
RCA_LOOP_INTERVAL_SEC=30
RCA_BUFFER_RETENTION_SEC=210
RCA_POST_TRIGGER_WAIT_SEC=180

# Optional local build context overrides. Defaults assume this repository and
# the four service repositories are siblings under services/.
# SPRING_BUILD_CONTEXT=../backend-spring
# FASTAPI_BUILD_CONTEXT=../api-fastapi
# FRONTEND_BUILD_CONTEXT=../frontend
# SDK_BUILD_CONTEXT=../py-sdk
